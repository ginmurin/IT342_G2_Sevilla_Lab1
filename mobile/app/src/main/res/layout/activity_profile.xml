<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Navigation Bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="4dp">

            <TextView
                android:id="@+id/tvProfileTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤  View Profile"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#333"
                android:layout_centerVertical="true" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true">

                <Button
                    android:id="@+id/btnBackToDashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="🏠 Dashboard"
                    android:textSize="13sp"
                    android:textColor="#1976D2"
                    android:background="?attr/selectableItemBackground"
                    android:layout_marginEnd="8dp"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp" />

                <Button
                    android:id="@+id/btnLogoutFromProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Logout"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/rounded_button_logout"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp" />

            </LinearLayout>

        </RelativeLayout>

        <!-- Profile Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#1976D2"
            android:padding="24dp">

            <!-- Profile Avatar Circle -->
            <TextView
                android:id="@+id/tvProfileAvatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/rounded_card"
                android:backgroundTint="#FFFFFF"
                android:text="👤"
                android:textSize="40sp"
                android:gravity="center"
                android:layout_centerVertical="true" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_toEndOf="@id/tvProfileAvatar"
                android:layout_centerVertical="true"
                android:layout_marginStart="20dp">

                <TextView
                    android:id="@+id/tvProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User Name"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvProfileUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@username"
                    android:textSize="16sp"
                    android:textColor="#E3F2FD" />

            </LinearLayout>

        </RelativeLayout>

        <!-- Profile Information Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:padding="20dp"
            android:layout_margin="16dp"
            android:elevation="3dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile Information"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#333"
                    android:layout_centerVertical="true" />

                <Button
                    android:id="@+id/btnEditProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="✏️ EDIT"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/rounded_button"
                    android:layout_alignParentEnd="true"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp" />

            </RelativeLayout>

            <!-- Username Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="👤"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Username"
                        android:textSize="12sp"
                        android:textColor="#999" />

                    <EditText
                        android:id="@+id/etUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@username"
                        android:textSize="16sp"
                        android:textColor="#333"
                        android:textStyle="bold"
                        android:background="@android:color/transparent"
                        android:enabled="false"
                        android:inputType="text"
                        android:padding="4dp" />

                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginVertical="8dp" />

            <!-- Email Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="📧"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email Address"
                        android:textSize="12sp"
                        android:textColor="#999" />

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="email@example.com"
                        android:textSize="16sp"
                        android:textColor="#333"
                        android:textStyle="bold"
                        android:background="@android:color/transparent"
                        android:enabled="false"
                        android:inputType="textEmailAddress"
                        android:padding="4dp" />

                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginVertical="8dp" />

            <!-- Name Row (First & Last) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="✏️"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="First Name"
                        android:textSize="12sp"
                        android:textColor="#999" />

                    <TextView
                        android:id="@+id/tvFirstName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="First"
                        android:textSize="16sp"
                        android:textColor="#333"
                        android:textStyle="bold"
                        android:padding="4dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last Name"
                        android:textSize="12sp"
                        android:textColor="#999" />

                    <TextView
                        android:id="@+id/tvLastName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last"
                        android:textSize="16sp"
                        android:textColor="#333"
                        android:textStyle="bold"
                        android:padding="4dp" />

                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginVertical="8dp" />

            <!-- Password Section (Only visible in edit mode) -->
            <LinearLayout
                android:id="@+id/passwordSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="🔒"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="New Password (optional)"
                        android:textSize="12sp"
                        android:textColor="#999" />

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Leave empty to keep current"
                        android:textSize="16sp"
                        android:textColor="#333"
                        android:background="@android:color/transparent"
                        android:inputType="textPassword"
                        android:padding="4dp" />

                </LinearLayout>

            </LinearLayout>

            <View
                android:id="@+id/passwordDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginVertical="8dp"
                android:visibility="gone" />

            <!-- Role Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="🔧"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Role"
                        android:textSize="12sp"
                        android:textColor="#999" />

                    <TextView
                        android:id="@+id/tvRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User"
                        android:textSize="16sp"
                        android:textColor="#333"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Account Status"
                        android:textSize="12sp"
                        android:textColor="#999" />

                    <TextView
                        android:id="@+id/tvAccountStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active"
                        android:textSize="16sp"
                        android:textColor="#00897B"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- Save/Cancel Buttons (Only visible in edit mode) -->
            <LinearLayout
                android:id="@+id/saveButtonsLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <Button
                    android:id="@+id/btnCancelEdit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cancel"
                    android:textSize="14sp"
                    android:textColor="#666"
                    android:background="?attr/selectableItemBackground"
                    android:layout_marginEnd="8dp"
                    android:padding="12dp" />

                <Button
                    android:id="@+id/btnSaveProfile"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💾 Save Changes"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/rounded_button"
                    android:layout_marginStart="8dp"
                    android:padding="12dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Access Permissions Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:padding="20dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Access Permissions"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Dashboard Access"
                android:textSize="14sp"
                android:textColor="#00897B"
                android:layout_marginBottom="6dp"
                android:drawableStart="@drawable/ic_check"
                android:drawablePadding="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• View Profile"
                android:textSize="14sp"
                android:textColor="#00897B"
                android:layout_marginBottom="6dp"
                android:drawableStart="@drawable/ic_check"
                android:drawablePadding="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Access Protected Pages"
                android:textSize="14sp"
                android:textColor="#00897B"
                android:drawableStart="@drawable/ic_check"
                android:drawablePadding="8dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
