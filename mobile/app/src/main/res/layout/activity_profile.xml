<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F9FAFB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Navigation Bar (matches web's bg-white shadow nav) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#FFFFFF"
            android:paddingHorizontal="16dp"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_centerVertical="true"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_user"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Profile icon" />

                <TextView
                    android:id="@+id/tvProfileTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View Profile"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#111827" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btnBackToDashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Dashboard"
                    android:textSize="13sp"
                    android:textColor="#374151"
                    android:background="?attr/selectableItemBackground"
                    android:layout_marginEnd="4dp"
                    android:paddingHorizontal="12dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp" />

                <Button
                    android:id="@+id/btnLogoutFromProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Logout"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/rounded_button_logout"
                    android:paddingHorizontal="16dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp" />

            </LinearLayout>

        </RelativeLayout>

        <!-- Profile Header with Gradient (matches web's bg-gradient-to-r from-blue-500 to-blue-600) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_blue"
            android:padding="28dp"
            android:minHeight="180dp">

            <!-- Avatar Circle -->
            <FrameLayout
                android:id="@+id/avatarFrame"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/circle_white"
                android:layout_centerVertical="true">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_user"
                    android:contentDescription="Profile avatar" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_toEndOf="@id/avatarFrame"
                android:layout_centerVertical="true"
                android:layout_marginStart="20dp">

                <TextView
                    android:id="@+id/tvProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User Name"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvProfileUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@username"
                    android:textSize="15sp"
                    android:textColor="#DBEAFE" />

            </LinearLayout>

        </RelativeLayout>

        <!-- Profile Information Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:padding="24dp"
            android:layout_margin="16dp"
            android:elevation="4dp">

            <!-- Header with Edit button -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile Information"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_centerVertical="true" />

                <Button
                    android:id="@+id/btnEditProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Edit Profile"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/rounded_button"
                    android:layout_alignParentEnd="true"
                    android:paddingHorizontal="16dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp" />

            </RelativeLayout>

            <!-- Username Row with blue icon badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_blue"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_user"
                        android:contentDescription="Username icon" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Username"
                        android:textSize="13sp"
                        android:textColor="#6B7280" />

                    <EditText
                        android:id="@+id/etUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@username"
                        android:textSize="16sp"
                        android:textColor="#111827"
                        android:textStyle="bold"
                        android:background="@android:color/transparent"
                        android:enabled="false"
                        android:inputType="text"
                        android:padding="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Email Row with green icon badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_green"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_login"
                        android:contentDescription="Email icon" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email Address"
                        android:textSize="13sp"
                        android:textColor="#6B7280" />

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="email@example.com"
                        android:textSize="16sp"
                        android:textColor="#111827"
                        android:textStyle="bold"
                        android:background="@android:color/transparent"
                        android:enabled="false"
                        android:inputType="textEmailAddress"
                        android:padding="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Password Section (Only visible in edit mode) -->
            <LinearLayout
                android:id="@+id/passwordSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_orange"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_shield"
                        android:contentDescription="Password icon" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="New Password (optional)"
                        android:textSize="13sp"
                        android:textColor="#6B7280" />

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Leave empty to keep current"
                        android:textSize="16sp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:background="@android:color/transparent"
                        android:inputType="textPassword"
                        android:padding="4dp" />

                </LinearLayout>

            </LinearLayout>

            <View
                android:id="@+id/passwordDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- First Name Row with purple icon badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_purple"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_user"
                        android:contentDescription="First name icon" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="First Name"
                        android:textSize="13sp"
                        android:textColor="#6B7280" />

                    <TextView
                        android:id="@+id/tvFirstName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="First"
                        android:textSize="16sp"
                        android:textColor="#111827"
                        android:textStyle="bold"
                        android:padding="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Last Name Row with pink icon badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_pink"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_user"
                        android:contentDescription="Last name icon" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last Name"
                        android:textSize="13sp"
                        android:textColor="#6B7280" />

                    <TextView
                        android:id="@+id/tvLastName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last"
                        android:textSize="16sp"
                        android:textColor="#111827"
                        android:textStyle="bold"
                        android:padding="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Role Row with orange icon badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_orange"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check"
                        android:contentDescription="Role icon" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Role"
                        android:textSize="13sp"
                        android:textColor="#6B7280" />

                    <TextView
                        android:id="@+id/tvRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User"
                        android:textSize="16sp"
                        android:textColor="#111827"
                        android:textStyle="bold"
                        android:padding="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Account Status Row with teal icon badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_teal"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_shield"
                        android:contentDescription="Status icon" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Account Status"
                        android:textSize="13sp"
                        android:textColor="#6B7280" />

                    <TextView
                        android:id="@+id/tvAccountStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active"
                        android:textSize="16sp"
                        android:textColor="#0D9488"
                        android:textStyle="bold"
                        android:padding="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Save/Cancel Buttons (Only visible in edit mode) -->
            <LinearLayout
                android:id="@+id/saveButtonsLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:visibility="gone">

                <Button
                    android:id="@+id/btnSaveProfile"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Save Changes"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/rounded_button_green"
                    android:layout_marginEnd="8dp"
                    android:minHeight="0dp" />

                <Button
                    android:id="@+id/btnCancelEdit"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Cancel"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/rounded_button_logout"
                    android:layout_marginStart="8dp"
                    android:minHeight="0dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Access Permissions Card (matches web's Access Permissions section) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:padding="24dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Access Permissions"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_marginBottom="14dp" />

            <!-- Permission items with green dots (matching web) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/circle_green"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dashboard Access"
                    android:textSize="14sp"
                    android:textColor="#374151" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/circle_green"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View Profile"
                    android:textSize="14sp"
                    android:textColor="#374151" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/circle_green"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Access Protected Pages"
                    android:textSize="14sp"
                    android:textColor="#374151" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
